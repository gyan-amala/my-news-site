---
layout: base.html
---

<div class="wrapper">
    
    <!-- 1. TOP SECTION: THE DAILY BRIEFING WIRE -->
    {% set latestBrief = collections.daily | reverse | first %}
    {% if latestBrief %}
    <section class="daily-brief-grid">
        <div class="brief-card status-quote">
            <span class="brief-badge">💬 QUOTE OF THE DAY</span>
            <p class="quote-text">"{{ latestBrief.data.quoteText }}"</p>
            <span class="quote-author">— {{ latestBrief.data.quoteAuthor }}</span>
        </div>
        
        <div class="brief-card status-history">
            <span class="brief-badge">⏳ ON THIS DAY</span>
            <h4 class="history-year">Year: {{ latestBrief.data.historyYear }}</h4>
            <p class="history-text">{{ latestBrief.data.historyEvent }}</p>
        </div>
        
        <div class="brief-card status-fact">
            <span class="brief-badge">💡 DID YOU KNOW?</span>
            <p class="fact-text">{{ latestBrief.data.randomFact }}</p>
        </div>
    </section>
    {% endif %}

    <!-- 2. MIDDLE SECTION: 70/30 SPLIT LAYOUT -->
    <div class="split-layout">
        
        <!-- LEFT: 70% MAIN FEED -->
        <main class="main-content">
            <div class="section-heading">
                <div class="heading-dot"></div>
                <h2>The Latest Wire</h2>
            </div>

            <div class="dynamic-feed">
                {% for article in collections.news | reverse | limit(3) %}
                <article class="news-card">
                    <div class="card-tag tag-{{ article.data.category }}">{{ article.data.category }}</div>
                    <h3 class="card-title"><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
                    <p class="card-excerpt">{{ article.data.excerpt }}</p>
                    <div class="card-meta">
                        <!-- DYNAMIC AUTHOR AND READ TIME -->
                        <span class="author">By {{ article.data.author | default("Desk Editor") }}</span> • 
                        <span class="read-time">{{ article.content | readingTime }}</span>
                    </div>
                </article>
                {% else %}
                <p class="empty-state-text">No news articles published yet.</p>
                {% endfor %}
            </div>
        </main>

         <!-- RIGHT: 30% SIDEBAR (NOW DYNAMIC) -->
        <aside class="sidebar">
            <div class="sidebar-widget">
                <h3 class="widget-title">🔥 Most Read</h3>
                <ul class="trending-list">
                    {% set rank = 1 %}
                    {% for article in collections.news %}
                        {% if article.data.trending == true and rank <= 5 %}
                        <li>
                            <span class="rank">{{ rank }}</span>
                            <a href="{{ article.url }}">{{ article.data.title }}</a>
                        </li>
                        {% set rank = rank + 1 %}
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        </aside>
    </div>

    <!-- 3. FULL WIDTH BREAK: TRENDING HIGHLIGHTS -->
    <section class="trending-banner">
        <div class="banner-badge">★ TOP STORIES</div>
        <div class="banner-grid">
            {% for article in collections.news %}
                {% if article.data.trending == true %}
                <div class="banner-card">
                    <h4><a href="{{ article.url }}">{{ article.data.title }}</a></h4>
                    <p>{{ article.data.excerpt }}</p>
                </div>
                {% endif %}
            {% endfor %}
        </div>
    </section>

    <!-- 4. FLUID CATEGORY GRID -->
    <section class="category-grid">
        <!-- Define the categories you want Eleventy to look for and generate columns for -->
        {% set activeCategories = ["polity", "economy", "science", "defence", "history", "geography"] %}
        
        {% for cat in activeCategories %}
            <!-- Check if any articles exist for this category -->
            {% set catHasArticles = false %}
            {% for article in collections.news %}
                {% if article.data.category == cat %}
                    {% set catHasArticles = true %}
                {% endif %}
            {% endfor %}

            <!-- If articles exist, automatically generate the HTML column -->
            {% if catHasArticles %}
            <div class="cat-column border-{{ cat }}">
                <h3 class="cat-header bg-{{ cat }}">{{ cat | capitalize }}</h3>
                <div class="cat-list">
                    {% for article in collections.news | reverse %}
                        {% if article.data.category == cat %}
                        <div class="mini-card">
                            <h4><a href="{{ article.url }}">{{ article.data.title }}</a></h4>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            {% endif %}
        {% endfor %}
    </section>

    <!-- 5. BOTTOM SECTION: THE THREE ARCHIVE BASKETS -->
    <section class="archive-baskets-section">
        <div class="section-heading">
            <div class="heading-dot basket-dot"></div>
            <h2>Knowledge Baskets (Back Issues)</h2>
        </div>
        
        <div class="baskets-grid">
            <div class="basket-card border-quote">
                <div class="basket-icon">🏺</div>
                <h3 class="basket-title">The Vault of Wisdom</h3>
                <p class="basket-desc">Missed a day? Take a stroll through every perspective, philosophy, and quote we've ever logged.</p>
                <a href="/archives/quotes/" class="basket-btn">Open Quote Basket →</a>
            </div>

            <div class="basket-card border-history">
                <div class="basket-icon">📜</div>
                <h3 class="basket-title">Echoes of Time</h3>
                <p class="basket-desc">A deep-dive chronological timeline of historic global and regional events occurring on this day.</p>
                <a href="/archives/history/" class="basket-btn">Open History Basket →</a>
            </div>

            <div class="basket-card border-fact">
                <div class="basket-icon">🧬</div>
                <h3 class="basket-title">The Curiosity Shop</h3>
                <p class="basket-desc">Uncover random facts, science anomalies, and mini trivia bits preserved from our daily logs.</p>
                <a href="/archives/facts/" class="basket-btn">Open Fact Basket →</a>
            </div>
        </div>
    </section>

</div>
