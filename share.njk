---
layout: base.html
title: "Secure File Drop | Gyan Amala"
permalink: /share/
---

<style>
  .share-wrapper {
    max-width: 900px;
    margin: 60px auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .share-card {
    background: var(--card-bg);
    padding: 40px 30px;
    border-radius: var(--radius);
    border: 1px solid #E2E8F0;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .share-icon {
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .share-card h2 {
    font-size: 1.6rem;
    color: var(--text-dark);
    margin-bottom: 10px;
  }

  .share-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 25px;
    line-height: 1.5;
  }

  /* Inputs & Buttons */
  .file-input-wrapper, .code-input {
    width: 100%;
    margin-bottom: 20px;
  }

  .code-input {
    padding: 12px 15px;
    font-size: 1.2rem;
    text-align: center;
    border: 2px dashed #CBD5E1;
    border-radius: 8px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--text-dark);
    text-transform: uppercase;
    outline: none;
    transition: border-color 0.2s;
  }
  .code-input:focus { border-color: var(--color-polity); }

  .action-btn {
    width: 100%;
    padding: 12px 20px;
    background: var(--color-polity);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  .action-btn:hover { background: #2563EB; box-shadow: var(--shadow-hover); }
  .action-btn:disabled { background: #94A3B8; cursor: not-allowed; box-shadow: none; }
  
  .btn-receive { background: var(--color-economy); }
  .btn-receive:hover { background: #059669; }

  /* Success Message Box */
  .result-box {
    display: none;
    width: 100%;
    margin-top: 20px;
    padding: 20px;
    background: #EFF6FF;
    border: 1px solid #BFDBFE;
    border-radius: 8px;
    color: #1E3A8A;
  }
  .secret-code {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 4px;
    margin: 10px 0;
    color: var(--color-polity);
  }
  .warning-text { font-size: 0.85rem; color: #DC2626; font-weight: 600; margin-top: 10px; display: block; }

</style>

<div class="wrapper">
  
  <!-- Header -->
  <div style="text-align: center; margin-top: 40px;">
    <h1 style="font-size: clamp(2rem, 4vw, 2.8rem); color: var(--text-dark);">Secure File Drop</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 10px auto 0;">Share files anonymously. Files are encrypted, completely free, and permanently destroyed the second they are downloaded.</p>
  </div>

  <div class="share-wrapper">
    
    <!-- 📤 SENDER CARD -->
    <div class="share-card">
      <div class="share-icon">📤</div>
      <h2>Send a File</h2>
      <p>Upload any file up to 2GB. We will generate a secure, one-time-use secret code.</p>
      
      <div class="file-input-wrapper">
        <input type="file" id="fileUpload" style="width: 100%; padding: 10px; border: 1px solid #E2E8F0; border-radius: 8px;">
      </div>
      
      <button id="sendBtn" class="action-btn">Upload & Get Code</button>

      <!-- The Hidden Result Box -->
      <div id="resultBox" class="result-box">
        <span>Your Secret Code is:</span>
        <span id="displayCode" class="secret-code">XYZ123</span>
        <span>Give this to the receiver.</span>
        <span class="warning-text">⚠️ This code expires immediately after one use.</span>
      </div>
    </div>

    <!-- 📥 RECEIVER CARD -->
    <div class="share-card">
      <div class="share-icon">📥</div>
      <h2>Receive a File</h2>
      <p>Enter your 6-character secret code below to instantly download your file.</p>
      
      <input type="text" id="receiveCode" class="code-input" placeholder="e.g. xY7z9P" maxlength="15">
      
      <button id="receiveBtn" class="action-btn btn-receive">Download File</button>
    </div>

  </div>
</div>

<script>
  // --- SENDER LOGIC ---
  const sendBtn = document.getElementById('sendBtn');
  const fileUpload = document.getElementById('fileUpload');
  const resultBox = document.getElementById('resultBox');
  const displayCode = document.getElementById('displayCode');

  sendBtn.addEventListener('click', async () => {
    const file = fileUpload.files[0];
    
    if (!file) {
      alert("Please select a file first.");
      return;
    }

    // Update UI for loading state
    sendBtn.innerText = "Uploading... Please wait";
    sendBtn.disabled = true;
    resultBox.style.display = 'none';

    // Package the file for the API
    const formData = new FormData();
    formData.append('file', file);

    try {
      // Send directly to the File.io API (No API key needed for basic free tier)
      const response = await fetch('https://file.io', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if (data.success) {
        // Success! Extract the unique key and show it to the user
        displayCode.textContent = data.key;
        resultBox.style.display = 'block';
        
        // Reset the input
        fileUpload.value = '';
      } else {
        alert("Upload failed. The file might be too large.");
      }

    } catch (error) {
      console.error("Upload Error:", error);
      alert("An error occurred while uploading. Please check your connection.");
    } finally {
      // Restore button state
      sendBtn.innerText = "Upload & Get Code";
      sendBtn.disabled = false;
    }
  });

  // --- RECEIVER LOGIC ---
  const receiveBtn = document.getElementById('receiveBtn');
  const receiveCode = document.getElementById('receiveCode');

  receiveBtn.addEventListener('click', () => {
    // Grab the code and remove any accidental spaces
    const code = receiveCode.value.trim();

    if (!code) {
      alert("Please enter a secret code first.");
      return;
    }

    // Redirect the user directly to the File.io download link
    // The browser will handle this as a standard file download
    window.location.href = `https://file.io/${code}`;
    
    // Clear the input box after clicking
    receiveCode.value = '';
  });

  // Allow hitting "Enter" to submit the receive code
  receiveCode.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      receiveBtn.click();
    }
  });
</script>

