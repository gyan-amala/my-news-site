<!-- Import the Supabase Library -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
  .share-wrapper {
    max-width: 900px;
    margin: 60px auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .share-card {
    background: var(--card-bg);
    padding: 40px 30px;
    border-radius: var(--radius);
    border: 1px solid #E2E8F0;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .share-icon { font-size: 3rem; margin-bottom: 15px; }
  .share-card h2 { font-size: 1.6rem; color: var(--text-dark); margin-bottom: 10px; }
  .share-card p { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5; }

  .file-input-wrapper, .code-input { width: 100%; margin-bottom: 20px; }

  .code-input {
    padding: 12px 15px;
    font-size: 1.2rem;
    text-align: center;
    border: 2px dashed #CBD5E1;
    border-radius: 8px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--text-dark);
    text-transform: uppercase;
    outline: none;
    transition: border-color 0.2s;
  }
  .code-input:focus { border-color: var(--color-polity); }

  .action-btn {
    width: 100%;
    padding: 12px 20px;
    background: var(--color-polity);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  .action-btn:hover { background: #2563EB; box-shadow: var(--shadow-hover); }
  .action-btn:disabled { background: #94A3B8; cursor: not-allowed; box-shadow: none; }
  
  .btn-receive { background: var(--color-economy); }
  .btn-receive:hover { background: #059669; }

  .result-box {
    display: none; width: 100%; margin-top: 20px; padding: 20px;
    background: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 8px; color: #1E3A8A;
  }
  .secret-code {
    display: block; font-size: 2rem; font-weight: 900; letter-spacing: 4px;
    margin: 10px 0; color: var(--color-polity);
  }
  .warning-text { font-size: 0.85rem; color: #DC2626; font-weight: 600; margin-top: 10px; display: block; }
</style>

<div class="wrapper">
  
  <div style="text-align: center; margin-top: 40px;">
    <h1 style="font-size: clamp(2rem, 4vw, 2.8rem); color: var(--text-dark);">Secure File Drop</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 10px auto 0;">Share files securely. The file is temporarily stored and permanently destroyed the second it is downloaded.</p>
  </div>

  <div class="share-wrapper">
    
    <!-- 📤 SENDER CARD -->
    <div class="share-card">
      <div class="share-icon">📤</div>
      <h2>Send a File</h2>
      <p>Upload a file. We will generate a secure 6-character secret code.</p>
      
      <div class="file-input-wrapper">
        <input type="file" id="fileUpload" style="width: 100%; padding: 10px; border: 1px solid #E2E8F0; border-radius: 8px;">
      </div>
      
      <button id="sendBtn" class="action-btn">Upload & Get Code</button>

      <div id="resultBox" class="result-box">
        <span>Your Secret Code is:</span>
        <span id="displayCode" class="secret-code"></span>
        <span>Give this to the receiver.</span>
        <span class="warning-text">⚠️ This code expires immediately after one use.</span>
      </div>
    </div>

    <!-- 📥 RECEIVER CARD -->
    <div class="share-card">
      <div class="share-icon">📥</div>
      <h2>Receive a File</h2>
      <p>Enter your 6-character secret code below to instantly download your file.</p>
      
      <input type="text" id="receiveCode" class="code-input" placeholder="e.g. A93K21" maxlength="6">
      
      <button id="receiveBtn" class="action-btn btn-receive">Download File</button>
    </div>

  </div>
</div>

<script>
  const supabaseUrl = 'https://ygosowoqpktyitknoyxl.supabase.co'; 
  const supabaseKey = 'sb_publishable_1JvKIo-CfPgQftYLA-4-rw_45xqWbNQ'; 
  
  const supabase = window.supabase.createClient(supabaseUrl, supabaseKey);

  const sendBtn = document.getElementById('sendBtn');
  const fileUpload = document.getElementById('fileUpload');
  const resultBox = document.getElementById('resultBox');
  const displayCode = document.getElementById('displayCode');

  sendBtn.addEventListener('click', async () => {
    const file = fileUpload.files[0];
    if (!file) return alert("Please select a file first.");

    sendBtn.innerText = "Uploading...";
    sendBtn.disabled = true;

    const code = Math.random().toString(36).substring(2, 8).toUpperCase();
    const filePath = `${code}_${file.name}`;

    try {
      // DEBUG: Step A - Try to upload
      const { data: upData, error: uploadError } = await supabase.storage
        .from('shared_files')
        .upload(filePath, file);
      
      if (uploadError) {
        alert("UPLOAD ERROR: " + uploadError.message);
        throw uploadError;
      }

      // DEBUG: Step B - Try to insert into database
      const { error: dbError } = await supabase
        .from('shares')
        .insert([{ code: code, file_path: filePath }]);

      if (dbError) {
        alert("DATABASE ERROR: " + dbError.message);
        throw dbError;
      }

      displayCode.textContent = code;
      resultBox.style.display = 'block';
      fileUpload.value = '';
      alert("Success!");

    } catch (error) {
      console.error("Full Error Details:", error);
    } finally {
      sendBtn.innerText = "Upload & Get Code";
      sendBtn.disabled = false;
    }
  });
  // ==========================================
  // RECEIVER LOGIC (DOWNLOAD & DESTROY)
  // ==========================================
  const receiveBtn = document.getElementById('receiveBtn');
  const receiveCode = document.getElementById('receiveCode');

  receiveBtn.addEventListener('click', async () => {
    const code = receiveCode.value.trim().toUpperCase();
    if (!code) return alert("Please enter a secret code.");

    receiveBtn.innerText = "Searching...";
    receiveBtn.disabled = true;

    try {
      // Step A: Check the Database Ledger for the code
      const { data: shareData, error: fetchError } = await supabase
        .from('shares')
        .select('file_path')
        .eq('code', code)
        .single();

      if (fetchError || !shareData) {
        alert("Code not found or file has already been downloaded.");
        receiveBtn.innerText = "Download File";
        receiveBtn.disabled = false;
        return;
      }

      const filePath = shareData.file_path;
      receiveBtn.innerText = "Downloading...";

      // Step B: Download the file from the Storage Bucket
      const { data: fileData, error: downloadError } = await supabase.storage
        .from('shared_files')
        .download(filePath);

      if (downloadError) throw downloadError;

      // Trigger the browser to save the file
      const originalFilename = filePath.substring(7); 
      const url = URL.createObjectURL(fileData);
      const a = document.createElement('a');
      a.href = url;
      a.download = originalFilename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      // Step C: Self-Destruct! Delete from Database and Storage
      await supabase.from('shares').delete().eq('code', code);
      await supabase.storage.from('shared_files').remove([filePath]);

      receiveCode.value = '';
      alert("Download complete! The file has now been permanently deleted from the server.");

    } catch (error) {
      console.error("Download Error:", error);
      alert("An error occurred while downloading.");
    } finally {
      receiveBtn.innerText = "Download File";
      receiveBtn.disabled = false;
    }
  });

  receiveCode.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') receiveBtn.click();
  });
</script>
