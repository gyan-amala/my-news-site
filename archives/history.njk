---
layout: base.html
permalink: /archives/history/
title: "Gyan Amala | Echoes of Time"
---

<div class="wrapper" style="margin-top: 50px; margin-bottom: 60px;">
    <div class="section-heading">
        <div class="heading-dot" style="background: var(--color-history);"></div>
        <h2>Echoes of Time (On This Day Archive)</h2>
    </div>
    
    <div style="display: flex; flex-direction: column; gap: 25px;">
        {% for brief in collections.daily | reverse %}
        <div style="background: var(--card-bg); padding: 30px; border-radius: var(--radius); box-shadow: var(--shadow-soft); border-left: 5px solid var(--color-history);">
            <h3 style="color: var(--color-history); margin-bottom: 10px; font-size: 1.4rem;">Year {{ brief.data.historyYear }}</h3>
            <p style="font-size: 1.1rem; color: var(--text-dark);">{{ brief.data.historyEvent }}</p>
            <small style="color: var(--text-muted); display: block; margin-top: 15px; font-size: 0.85rem;">Logged on: {{ brief.data.date | readableDate }}</small>
        </div>
        {% else %}
        <p style="color: var(--text-muted);">No historical events logged yet.</p>
        {% endfor %}
    </div>
</div>
