---
layout: base.html
permalink: /archives/quotes/
title: "Gyan Amala | The Vault of Wisdom"
---

<div class="wrapper" style="margin-top: 50px; margin-bottom: 60px;">
    <div class="section-heading">
        <div class="heading-dot" style="background: var(--color-polity);"></div>
        <h2>The Vault of Wisdom (All Quotes)</h2>
    </div>
    
    <div style="display: flex; flex-direction: column; gap: 25px;">
        {% for brief in collections.daily | reverse %}
        <div style="background: var(--card-bg); padding: 30px; border-radius: var(--radius); box-shadow: var(--shadow-soft); border-left: 5px solid var(--color-polity);">
            <p style="font-size: 1.2rem; font-weight: 500; margin-bottom: 15px; color: var(--text-dark);">"{{ brief.data.quoteText }}"</p>
            <p style="color: var(--text-muted); font-weight: 700; text-align: right;">— {{ brief.data.quoteAuthor }}</p>
            <small style="color: var(--text-muted); display: block; margin-top: 15px; font-size: 0.85rem;">Logged on: {{ brief.data.date | readableDate }}</small>
        </div>
        {% else %}
        <p style="color: var(--text-muted);">No quotes logged yet. Run your Google Apps Script briefing to populate this basket!</p>
        {% endfor %}
    </div>
</div>
