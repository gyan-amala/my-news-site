---
layout: base.html
permalink: /archives/facts/
title: "Gyan Amala | The Curiosity Shop"
---

<div class="wrapper" style="margin-top: 50px; margin-bottom: 60px;">
    <div class="section-heading">
        <div class="heading-dot" style="background: var(--color-science);"></div>
        <h2>The Curiosity Shop (Fact Archive)</h2>
    </div>
    
    <div style="display: flex; flex-direction: column; gap: 25px;">
        {% for brief in collections.daily | reverse %}
        <div style="background: var(--card-bg); padding: 30px; border-radius: var(--radius); box-shadow: var(--shadow-soft); border-left: 5px solid var(--color-science);">
            <span style="font-size: 0.75rem; font-weight: 800; color: var(--color-science); display: block; margin-bottom: 10px; letter-spacing: 1px;">FACT LOGGER</span>
            <p style="font-size: 1.1rem; line-height: 1.6; color: var(--text-dark);">{{ brief.data.randomFact }}</p>
            <small style="color: var(--text-muted); display: block; margin-top: 15px; font-size: 0.85rem;">Logged on: {{ brief.data.date | readableDate }}</small>
        </div>
        {% else %}
        <p style="color: var(--text-muted);">No facts logged yet.</p>
        {% endfor %}
    </div>
</div>
