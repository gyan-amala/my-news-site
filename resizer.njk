---
layout: base.html
title: "Pro Image Resizer | Gyan Amala"
permalink: /resizer/
---

<!-- Tool-Specific Styles -->
<style>
  .resizer-ui { max-width: 650px; margin: 40px auto; background: var(--card-bg); padding: 30px; border-radius: var(--radius); border: 1px solid #E2E8F0; box-shadow: var(--shadow-soft); }
  .control-group { margin-bottom: 1.5rem; display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
  .control-group label { display: block; font-size: 0.95rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--text-dark); }
  .control-group input[type="number"], .control-group select { padding: 0.5rem; width: 120px; border: 1px solid #E2E8F0; border-radius: 4px; font-family: inherit; }
  
  .checkbox-group { display: flex; align-items: center; gap: 0.5rem; margin-top: 1.25rem; }
  .checkbox-group label { margin: 0; cursor: pointer; }
  
  .preview-container { margin-top: 2rem; border: 2px dashed #E2E8F0; padding: 1.5rem; text-align: center; border-radius: 8px; }
  #preview { max-width: 100%; height: auto; display: none; margin-top: 1rem; border-radius: 4px; box-shadow: var(--shadow-soft); }
  .file-size-badge { display: none; font-weight: bold; color: var(--color-economy); margin-top: 10px; font-size: 1.1rem; }
  
  .action-btn { padding: 0.75rem 1.5rem; background: var(--color-polity); color: white; border: none; border-radius: 6px; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .action-btn:hover { background: #2563EB; box-shadow: var(--shadow-hover); }
  .action-btn:disabled { background: #94A3B8; cursor: not-allowed; box-shadow: none; }
</style>

<!-- Using your existing wrapper for proper site alignment -->
<div class="wrapper">
  
  <div class="resizer-ui">
    <h2 style="margin-bottom: 20px;">Optimize Your Images</h2>
    
    <div class="control-group">
      <input type="file" id="upload" accept="image/png, image/jpeg, image/webp, image/avif">
    </div>

    <div class="control-group">
      <div>
        <label for="width">Width (px)</label>
        <input type="number" id="width" disabled>
      </div>
      <div>
        <label for="height">Height (px)</label>
        <input type="number" id="height" disabled>
      </div>
      <div class="checkbox-group">
        <input type="checkbox" id="lockRatio" checked>
        <label for="lockRatio">Keep Aspect Ratio</label>
      </div>
    </div>

    <div class="control-group">
      <div>
        <label for="format">Output Format</label>
        <select id="format">
          <option value="image/webp">WebP (Best for web)</option>
          <option value="image/jpeg">JPEG</option>
          <option value="image/png">PNG</option>
        </select>
      </div>
      <div>
        <label for="quality">Quality (<span id="qualityVal">80</span>%)</label>
        <input type="range" id="quality" min="10" max="100" value="80" style="width: 150px;">
      </div>
      <div>
        <!-- NEW: Max File Size Input -->
        <label for="maxSize">Max Size (KB) <i>(Optional)</i></label>
        <input type="number" id="maxSize" placeholder="e.g. 50">
      </div>
    </div>

    <button id="processBtn" class="action-btn" disabled>Generate & Download</button>

    <div class="preview-container">
      <p style="margin:0; color:var(--text-muted);">Live Preview</p>
      <img id="preview" alt="Resized preview">
      <!-- NEW: Display the final file size so the user knows it worked -->
      <div id="finalSize" class="file-size-badge"></div>
    </div>
  </div>

</div>

<!-- Load Pica Library -->
<script src="https://cdn.jsdelivr.net/npm/pica@9.0.1/dist/pica.min.js"></script>

<!-- The Resizer Logic -->
<script>
  const state = { originalImage: new Image(), originalRatio: 1, currentFileName: '' };
  const els = {
    upload: document.getElementById('upload'), 
    width: document.getElementById('width'),
    height: document.getElementById('height'), 
    lockRatio: document.getElementById('lockRatio'),
    format: document.getElementById('format'), 
    quality: document.getElementById('quality'),
    qualityVal: document.getElementById('qualityVal'), 
    maxSize: document.getElementById('maxSize'),
    processBtn: document.getElementById('processBtn'),
    preview: document.getElementById('preview'),
    finalSize: document.getElementById('finalSize')
  };

  const picaRunner = pica();

  els.upload.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    state.currentFileName = file.name;
    const reader = new FileReader();
    reader.onload = (event) => {
      state.originalImage.onload = () => {
        els.width.value = state.originalImage.width;
        els.height.value = state.originalImage.height;
        state.originalRatio = state.originalImage.width / state.originalImage.height;
        els.width.disabled = false; els.height.disabled = false; els.processBtn.disabled = false;
        els.preview.style.display = 'none'; els.finalSize.style.display = 'none';
      };
      state.originalImage.src = event.target.result;
    };
    reader.readAsDataURL(file);
  });

  els.width.addEventListener('input', () => {
    if (els.lockRatio.checked && state.originalImage.src) els.height.value = Math.round(els.width.value / state.originalRatio);
  });

  els.height.addEventListener('input', () => {
    if (els.lockRatio.checked && state.originalImage.src) els.width.value = Math.round(els.height.value * state.originalRatio);
  });

  els.quality.addEventListener('input', (e) => els.qualityVal.textContent = e.target.value);

  els.processBtn.addEventListener('click', async () => {
    if (!state.originalImage.src) return;
    els.processBtn.textContent = 'Compressing...'; els.processBtn.disabled = true;
    els.finalSize.style.display = 'none';

    let targetWidth = parseInt(els.width.value, 10);
    let targetHeight = parseInt(els.height.value, 10);
    const mimeType = els.format.value;
    let qualityFloat = parseInt(els.quality.value, 10) / 100;
    
    // Grab the Target Size in Bytes
    const maxSizeInput = els.maxSize.value;
    const targetSizeBytes = maxSizeInput ? parseInt(maxSizeInput, 10) * 1024 : null;

    const srcCanvas = document.createElement('canvas');
    srcCanvas.width = state.originalImage.width; srcCanvas.height = state.originalImage.height;
    srcCanvas.getContext('2d').drawImage(state.originalImage, 0, 0);

    let currentCanvas = document.createElement('canvas');
    currentCanvas.width = targetWidth; currentCanvas.height = targetHeight;

    try {
      // 1. Initial Resize
      await picaRunner.resize(srcCanvas, currentCanvas, { unsharpAmount: 80, unsharpRadius: 0.6, unsharpThreshold: 2 });
      let blob = await picaRunner.toBlob(currentCanvas, mimeType, qualityFloat);

      // 2. The Smart Loop: If it's too big, compress it further
      if (targetSizeBytes) {
        
        // Step A: Drop the quality incrementally (Doesn't work well for PNG, so mainly WebP/JPEG)
        if (mimeType !== 'image/png') {
           while (blob.size > targetSizeBytes && qualityFloat > 0.1) {
             qualityFloat -= 0.1;
             blob = await picaRunner.toBlob(currentCanvas, mimeType, qualityFloat);
           }
        }

        // Step B: If it's STILL too big, start shrinking the physical dimensions by 15% at a time
        let safetyCounter = 0;
        while (blob.size > targetSizeBytes && targetWidth > 100 && safetyCounter < 10) {
           safetyCounter++;
           targetWidth = Math.round(targetWidth * 0.85);
           targetHeight = Math.round(targetHeight * 0.85);
           
           const newCanvas = document.createElement('canvas');
           newCanvas.width = targetWidth; newCanvas.height = targetHeight;
           
           await picaRunner.resize(srcCanvas, newCanvas, { unsharpAmount: 80, unsharpRadius: 0.6, unsharpThreshold: 2 });
           currentCanvas = newCanvas;
           blob = await picaRunner.toBlob(currentCanvas, mimeType, qualityFloat);
        }
        
        // Final sanity check
        if (blob.size > targetSizeBytes) {
            alert(`Could not compress it under ${maxSizeInput}KB without completely ruining the image. Closest achieved is ${(blob.size / 1024).toFixed(1)} KB.`);
        }
      }

      // 3. Display and Download
      const blobUrl = URL.createObjectURL(blob);
      els.preview.src = blobUrl; els.preview.style.display = 'inline-block';
      
      const finalKb = (blob.size / 1024).toFixed(1);
      els.finalSize.textContent = `Final File Size: ${finalKb} KB`;
      els.finalSize.style.display = 'block';

      const downloadLink = document.createElement('a');
      downloadLink.href = blobUrl;
      const baseName = state.currentFileName.substring(0, state.currentFileName.lastIndexOf('.'));
      downloadLink.download = `${baseName}-optimized.${mimeType.split('/')[1]}`;
      downloadLink.click();

    } catch (error) {
      console.error("Resizing failed:", error);
      alert("Something went wrong while processing the image.");
    } finally {
      els.processBtn.textContent = 'Generate & Download'; els.processBtn.disabled = false;
    }
  });
</script>
