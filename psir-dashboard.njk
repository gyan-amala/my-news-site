---
layout: base.html
permalink: /psir/index.html
title: "UPSC PSIR Optional Master Hub"
---

<div class="psir-dashboard-wrapper">
  
  <!-- 🌟 DASHBOARD HEADER -->
  <header class="psir-dash-header">
    <h1>📚 PSIR Optional Study Hub</h1>
    <p>Access comprehensive chapter-wise study notes, solved Previous Year Questions (PYQs), and high-yield model answers structured explicitly for the UPSC Examination.</p>
  </header>

  <!-- 🎛️ JAVASCRIPT FILTER BAR -->
  <div class="filter-bar" aria-label="Content Filter">
    <button class="filter-btn active" data-filter="all">All Content</button>
    <button class="filter-btn" data-filter="Note">📝 Core Notes</button>
    <button class="filter-btn" data-filter="PYQ">✍️ PYQs</button>
    <button class="filter-btn" data-filter="ModelAnswer">💡 Model Answers</button>
  </div>

  <!-- 🏛️ DYNAMIC NESTED FOLDERS (PAPER -> SECTION -> TOPIC) -->
  <div class="psir-columns">
    
    {% for paper, sections in collections.psirTree %}
    <section class="paper-column">
      <div class="paper-header">
        <h2>Paper {{ paper }}</h2>
      </div>

      <div class="paper-content">
        {% for section, topics in sections %}
        <!-- SECTION FOLDER -->
        <details class="folder-section" open>
          <summary class="folder-summary section-summary">📁 Section {{ section }}</summary>
          
          <div class="folder-content">
            {% for topic, notes in topics %}
            <!-- TOPIC FOLDER -->
            <details class="folder-topic" open>
              <summary class="folder-summary topic-summary">📂 {{ topic }}</summary>
              
              <div class="cards-list">
                {% for note in notes %}
                <!-- INDIVIDUAL NOTE CARD (With invisible data-type for filtering) -->
                <div class="note-card" data-type="{{ note.data.contentType }}">
                  <div class="note-card-header">
                    {% if note.data.contentType == "PYQ" %}
                      <span class="badge badge-pyq">✍️ PYQ {{ note.data.year }}</span>
                    {% elif note.data.contentType == "ModelAnswer" %}
                      <span class="badge badge-model">💡 Model Answer</span>
                    {% else %}
                      <span class="badge badge-note">📝 Note</span>
                    {% endif %}
                  </div>

                  <h3 class="note-title">{{ note.data.title }}</h3>
                  
                  {% if note.data.subTopic %}
                    <p class="note-focus">Focus: <strong>{{ note.data.subTopic }}</strong></p>
                  {% endif %}

                  <a href="{{ note.url }}" class="read-btn" aria-label="Read more about {{ note.data.title }}">
                    Read Material →
                  </a>
                </div>
                {% endfor %}
              </div>
            </details>
            {% endfor %}
          </div>
        </details>
        {% endfor %}
      </div>
    </section>
    {% endfor %}

  </div>
</div>

<!-- ⚙️ THE FILTER SCRIPT -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.note-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active class from all buttons, add to the clicked one
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Get the requested filter type
        const filter = btn.getAttribute('data-filter');

        // Show/Hide cards instantly without reloading
        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-type') === filter) {
            card.style.display = 'flex'; // Maintain flexbox layout when shown
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
