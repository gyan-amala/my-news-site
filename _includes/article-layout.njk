---
layout: base.html
---

<div class="article-container">
    
    <!-- Navigation -->
    <a href="/" class="back-link">
        ← Back to Newsroom
    </a>
    
    <!-- Article Header -->
    <header class="article-header">
        <!-- Category Badge -->
        <span class="card-tag tag-{{ category }}">{{ category }}</span>
        
        <h1 class="article-title">
            {{ title }}
        </h1>
        
        <!-- Meta Information -->
        <div class="article-meta">
            By {{ author | default("Desk Editor") }} • {{ category | capitalize }} Bureau
        </div>
    </header>
    
    <!-- 🌟 THE ARTICLE BODY 🌟 -->
    <article class="article-content">
        {{ content | safe }}
    </article>
     

    <div style="margin-top: 60px; padding-top: 30px; border-top: 1px solid #E2E8F0;">
        <h3 style="margin-bottom: 10px; color: var(--text-dark);">Share Your Thoughts</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 20px;">
            Have a question, correction, or private feedback about this piece? Send a note directly to our editorial desk. (Your message will remain private).
        </p>
        
        <iframe src="https://tally.so/embed/zxoBjR?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&formEventsForwarding=1" width="100%" height="250" frameborder="0" marginheight="0" marginwidth="0" title="Private Feedback"></iframe>
    </div>

</div>
