---
layout: base.html
---

<div class="psir-article-container">
  
  <!-- 🗺️ BREADCRUMB NAVIGATION -->
  <nav class="psir-breadcrumb" aria-label="Breadcrumbs">
    <a href="/psir/" class="breadcrumb-link">← PSIR Hub</a>
    <span class="breadcrumb-divider">/</span>
    <span>Paper {{ paper }}</span>
    <span class="breadcrumb-divider">/</span>
    <span>Section {{ section }}</span>
    {% if topic %}
      <span class="breadcrumb-divider">/</span>
      <span class="breadcrumb-current">{{ topic }}</span>
    {% endif %}
  </nav>

  <!-- 📝 ARTICLE HEADER -->
  <header class="psir-article-header">
    <div class="psir-badge-row">
      
      <!-- Dynamic Content Type Badge -->
      {% if contentType == "PYQ" %}
        <span class="badge badge-pyq">
          ✍️ PYQ {{ year }}
        </span>
      {% elif contentType == "ModelAnswer" %}
        <span class="badge badge-model">
          💡 Model Answer
        </span>
      {% else %}
        <span class="badge badge-note">
          📝 Core Note
        </span>
      {% endif %}

      {% if subTopic %}
        <span class="psir-topic-focus">• Topic Focus: <strong>{{ subTopic }}</strong></span>
      {% endif %}
    </div>

    <!-- Note Title -->
    <h1 class="psir-title">
      {{ title }}
    </h1>
  </header>

  <!-- 📖 NOTE BODY CONTENT -->
  <article class="psir-content">
    {{ content | safe }}
  </article>
  <article class="psir-content">
    {{ content | safe }}
  </article>

  <div style="margin-top: 60px; padding-top: 30px; border-top: 1px solid #E2E8F0;">
      <h3 style="margin-bottom: 10px; color: var(--text-dark);">Have a question?</h3>
      <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 20px;">
          Need clarification on this topic or spotted an error in the notes? Let us know below.
      </p>
      
      <iframe src="https://tally.so/embed/zxoBjR?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&formEventsForwarding=1" width="100%" height="250" frameborder="0" marginheight="0" marginwidth="0" title="Private Feedback"></iframe>
  </div>

  

  <!-- 🔙 BOTTOM NAVIGATION BAR -->
  <div class="psir-footer-nav">
    <a href="/psir/" class="return-btn">
      Return to PSIR Study Hub
    </a>
  </div>

</div>
