<!-- Tool-Specific Styles -->
<style>
  /* Base Container */
  .sudoku-ui {
    width: 100%;
    max-width: 500px;
    margin: 20px auto;
    background: var(--card-bg, #ffffff);
    padding: clamp(15px, 4vw, 30px) clamp(10px, 3vw, 20px);
    border-radius: var(--radius, 12px);
    border: 1px solid #E2E8F0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    box-sizing: border-box;
  }

  .sudoku-header { text-align: center; margin-bottom: 20px; }
  .sudoku-header h2 { font-size: clamp(1.4rem, 5vw, 1.8rem); margin-bottom: 5px; color: var(--text-dark, #0F172A); }
  .sudoku-header p { color: var(--text-muted, #64748B); font-size: clamp(0.85rem, 3vw, 0.95rem); margin: 0; }

  /* Controls */
  .diff-controls { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .diff-btn {
    background: #F1F5F9;
    border: 1px solid #E2E8F0;
    padding: 8px 16px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--text-muted, #64748B);
    transition: all 0.2s;
    flex: 1;
    max-width: 100px;
  }
  .diff-btn:hover { border-color: var(--color-polity, #3B82F6); color: var(--text-dark, #0F172A); }
  .diff-btn.active { background: var(--text-dark, #0F172A); color: white; border-color: var(--text-dark, #0F172A); }

  /* The Grid - Fully Fluid */
  .sudoku-board {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    grid-template-rows: repeat(9, 1fr);
    width: 100%;
    max-width: min(100%, 65vh); 
    aspect-ratio: 1;
    margin: 0 auto 25px auto;
    border: 2px solid var(--text-dark, #0F172A);
    background: var(--text-dark, #0F172A);
    gap: 1px;
  }

  .cell {
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(1rem, 4.5vw, 1.4rem);
    font-weight: 700;
    cursor: pointer;
    user-select: none;
    transition: background 0.1s;
    padding: 0;
  }

  /* 3x3 Block Styling */
  .cell:nth-child(3n) { border-right: 2px solid var(--text-dark, #0F172A); }
  .cell:nth-child(9n) { border-right: none; }
  .cell:nth-child(n+19):nth-child(-n+27),
  .cell:nth-child(n+46):nth-child(-n+54) { border-bottom: 2px solid var(--text-dark, #0F172A); }

  /* Cell States */
  .cell.fixed { color: var(--text-dark, #0F172A); cursor: default; background: #F8FAFC; }
  .cell.user-input { color: var(--color-polity, #3B82F6); }
  .cell.selected { background: #EFF6FF !important; outline: 2px solid var(--color-polity, #3B82F6); z-index: 10; }
  .cell.error { color: var(--color-history, #EF4444); background: #FEF2F2 !important; }

  /* Mobile-Optimized Numpad (2 rows of 5) */
  .numpad {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }
  .num-btn {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    padding: clamp(8px, 2vw, 12px) 0;
    border-radius: 8px;
    font-size: clamp(1.1rem, 4vw, 1.2rem);
    font-weight: 700;
    color: var(--text-dark, #0F172A);
    cursor: pointer;
    transition: background 0.1s;
    touch-action: manipulation; 
  }
  .num-btn:active { background: #E2E8F0; }
  
  .btn-erase { 
    grid-column: span 2; 
    background: #FEF2F2; 
    color: var(--color-history, #EF4444); 
    border-color: #FECACA; 
    font-size: clamp(0.9rem, 3.5vw, 1rem);
  }

  /* Win Message */
  .win-overlay {
    display: none; text-align: center; margin-top: 20px;
    padding: 15px; background: #ECFDF5; border: 1px solid #10B981;
    color: #065F46; border-radius: 8px; font-weight: 700;
  }
</style>

<div class="wrapper">
  <div class="sudoku-ui">
    
    <div class="sudoku-header">
      <h2>Brain Break</h2>
      <p>Clear your mind. No news, just numbers.</p>
    </div>

    <div class="diff-controls" aria-label="Difficulty">
      <button class="diff-btn active" data-diff="easy">Easy</button>
      <button class="diff-btn" data-diff="medium">Medium</button>
      <button class="diff-btn" data-diff="hard">Hard</button>
    </div>

    <div id="board" class="sudoku-board"></div>

    <div class="numpad">
      <button class="num-btn" data-val="1">1</button>
      <button class="num-btn" data-val="2">2</button>
      <button class="num-btn" data-val="3">3</button>
      <button class="num-btn" data-val="4">4</button>
      <button class="num-btn" data-val="5">5</button>
      <button class="num-btn" data-val="6">6</button>
      <button class="num-btn" data-val="7">7</button>
      <button class="num-btn" data-val="8">8</button>
      <button class="num-btn" data-val="9">9</button>
      <button class="num-btn btn-erase" data-val="0">⌫ Erase</button>
    </div>

    <div id="win-message" class="win-overlay">
      🎉 Puzzle Solved! Great job.
    </div>

  </div>
</div>

<!-- Open Source Sudoku Generator Library -->
<script src="https://cdn.jsdelivr.net/npm/sudoku-gen@2.1.2/dist/sudoku-gen.min.js"></script>

<script>
  // Game State
  const state = {
    puzzle: [],
    solution: [],
    userGrid: [],
    selectedCell: null
  };

  const els = {
    board: document.getElementById('board'),
    diffBtns: document.querySelectorAll('.diff-btn'),
    numBtns: document.querySelectorAll('.num-btn'),
    winMsg: document.getElementById('win-message')
  };

  // --- 1. AUTO-SAVE LOGIC ---
  function saveGame() {
    localStorage.setItem('gyanAmalaSudoku', JSON.stringify({
      puzzle: state.puzzle,
      solution: state.solution,
      userGrid: state.userGrid
    }));
  }

  function loadGame() {
    const saved = localStorage.getItem('gyanAmalaSudoku');
    if (saved) {
      const parsed = JSON.parse(saved);
      state.puzzle = parsed.puzzle;
      state.solution = parsed.solution;
      state.userGrid = parsed.userGrid;
      return true;
    }
    return false;
  }

  function clearSavedGame() {
    localStorage.removeItem('gyanAmalaSudoku');
  }

  // --- 2. SUDOKU GENERATOR (Using open-source library) ---
  function generateBoard(difficulty) {
    let libDifficulty = 'easy';
    if (difficulty === 'medium') libDifficulty = 'medium';
    if (difficulty === 'hard') libDifficulty = 'hard';

    const generated = window.getSudoku(libDifficulty);

    const stringToArray = (str) => {
      let grid = [];
      for (let r = 0; r < 9; r++) {
        let row = [];
        for (let c = 0; c < 9; c++) {
          let char = str[r * 9 + c];
          row.push(char === '-' ? 0 : parseInt(char));
        }
        grid.push(row);
      }
      return grid;
    };

    state.puzzle = stringToArray(generated.puzzle);
    state.solution = stringToArray(generated.solution);
    state.userGrid = state.puzzle.map(row => [...row]);
    
    saveGame(); 
  }

  // --- 3. UI RENDERING ---
  function renderBoard() {
    els.board.innerHTML = '';
    els.winMsg.style.display = 'none';

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        let cell = document.createElement('div');
        cell.classList.add('cell');
        cell.dataset.r = r;
        cell.dataset.c = c;

        let val = state.userGrid[r][c];
        if (val !== 0) cell.textContent = val;

        if (state.puzzle[r][c] !== 0) {
          cell.classList.add('fixed');
        } else if (val !== 0) {
          cell.classList.add('user-input');
        }

        cell.addEventListener('click', () => selectCell(r, c));
        els.board.appendChild(cell);
      }
    }
    checkErrors();
  }

  function selectCell(r, c) {
    if(state.puzzle[r][c] !== 0) return; 
    
    document.querySelectorAll('.cell').forEach(el => el.classList.remove('selected'));
    state.selectedCell = { r, c };
    
    let target = document.querySelector(`.cell[data-r="${r}"][data-c="${c}"]`);
    if(target) target.classList.add('selected');
  }

  // --- 4. INPUT HANDLING & VALIDATION ---
  function inputNumber(num) {
    if(!state.selectedCell) return;
    let {r, c} = state.selectedCell;
    
    state.userGrid[r][c] = num;
    saveGame(); 
    renderBoard();
    
    selectCell(r, c);
    checkWin();
  }

  function checkErrors() {
    let cells = document.querySelectorAll('.cell');
    cells.forEach(c => c.classList.remove('error'));

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        let val = state.userGrid[r][c];
        if(val === 0 || state.puzzle[r][c] !== 0) continue; 

        if(val !== state.solution[r][c]) {
           let el = document.querySelector(`.cell[data-r="${r}"][data-c="${c}"]`);
           if(el) el.classList.add('error');
        }
      }
    }
  }

  function checkWin() {
    let isFull = true;
    let isCorrect = true;

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        if(state.userGrid[r][c] === 0) isFull = false;
        if(state.userGrid[r][c] !== state.solution[r][c]) isCorrect = false;
      }
    }

    if(isFull && isCorrect) {
      els.winMsg.style.display = 'block';
      state.selectedCell = null;
      document.querySelectorAll('.cell').forEach(el => el.classList.remove('selected'));
      clearSavedGame(); 
    }
  }

  // --- 5. EVENT LISTENERS ---
  els.diffBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      els.diffBtns.forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      generateBoard(e.target.dataset.diff);
      state.selectedCell = null;
      renderBoard();
    });
  });

  els.numBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      inputNumber(parseInt(e.target.dataset.val));
    });
  });

  document.addEventListener('keydown', (e) => {
    if(e.key >= '1' && e.key <= '9') {
      inputNumber(parseInt(e.key));
    } else if (e.key === 'Backspace' || e.key === 'Delete') {
      inputNumber(0);
    }
  });

  // --- 6. INITIALIZATION ---
  if (!loadGame()) {
    generateBoard('easy');
  }
  renderBoard();
</script>
