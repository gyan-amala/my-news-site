layout: base.html
title: "Sudoku Brain Break | Gyan Amala"
permalink: /sudoku/
---

<!-- Tool-Specific Styles -->
<style>
  .sudoku-ui {
    max-width: 500px;
    margin: 40px auto;
    background: var(--card-bg);
    padding: 30px 20px;
    border-radius: var(--radius);
    border: 1px solid #E2E8F0;
    box-shadow: var(--shadow-soft);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .sudoku-header { text-align: center; margin-bottom: 25px; }
  .sudoku-header h2 { font-size: 1.8rem; margin-bottom: 10px; color: var(--text-dark); }
  .sudoku-header p { color: var(--text-muted); font-size: 0.95rem; }

  /* Controls */
  .diff-controls { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
  .diff-btn {
    background: #F1F5F9;
    border: 1px solid #E2E8F0;
    padding: 8px 16px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.2s;
  }
  .diff-btn:hover { border-color: var(--color-polity); color: var(--text-dark); }
  .diff-btn.active { background: var(--text-dark); color: white; border-color: var(--text-dark); }

  /* The Grid */
  .sudoku-board {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    width: 100%;
    max-width: 400px;
    margin: 0 auto 25px auto;
    border: 2px solid var(--text-dark);
    background: var(--text-dark);
    gap: 1px; /* Creates the thin inner borders */
  }

  .cell {
    background: white;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 700;
    cursor: pointer;
    user-select: none;
    transition: background 0.1s;
  }

  /* 3x3 Block Styling (Thick borders) */
  .cell:nth-child(3n) { border-right: 2px solid var(--text-dark); }
  .cell:nth-child(9n) { border-right: none; }
  .cell:nth-child(n+19):nth-child(-n+27),
  .cell:nth-child(n+46):nth-child(-n+54) { border-bottom: 2px solid var(--text-dark); }

  /* Cell States */
  .cell.fixed { color: var(--text-dark); cursor: default; background: #F8FAFC; }
  .cell.user-input { color: var(--color-polity); }
  .cell.selected { background: #EFF6FF !important; outline: 2px solid var(--color-polity); z-index: 10; }
  .cell.error { color: var(--color-history); background: #FEF2F2 !important; }

  /* Mobile Numpad */
  .numpad {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    max-width: 400px;
    margin: 0 auto;
  }
  .num-btn {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    padding: 12px 0;
    border-radius: 8px;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-dark);
    cursor: pointer;
    transition: background 0.1s;
  }
  .num-btn:active { background: #E2E8F0; }
  .btn-erase { grid-column: span 5; background: #FEF2F2; color: var(--color-history); border-color: #FECACA; }

  /* Win Message */
  .win-overlay {
    display: none; text-align: center; margin-top: 20px;
    padding: 15px; background: #ECFDF5; border: 1px solid #10B981;
    color: #065F46; border-radius: 8px; font-weight: 700;
  }
</style>

<div class="wrapper">
  <div class="sudoku-ui">
    
    <div class="sudoku-header">
      <h2>Brain Break</h2>
      <p>Clear your mind. No news, just numbers.</p>
    </div>

    <div class="diff-controls" aria-label="Difficulty">
      <button class="diff-btn active" data-diff="easy">Easy</button>
      <button class="diff-btn" data-diff="medium">Medium</button>
      <button class="diff-btn" data-diff="hard">Hard</button>
    </div>

    <div id="board" class="sudoku-board"></div>

    <div class="numpad">
      <button class="num-btn" data-val="1">1</button>
      <button class="num-btn" data-val="2">2</button>
      <button class="num-btn" data-val="3">3</button>
      <button class="num-btn" data-val="4">4</button>
      <button class="num-btn" data-val="5">5</button>
      <button class="num-btn" data-val="6">6</button>
      <button class="num-btn" data-val="7">7</button>
      <button class="num-btn" data-val="8">8</button>
      <button class="num-btn" data-val="9">9</button>
      <button class="num-btn btn-erase" data-val="0">⌫ Erase</button>
    </div>

    <div id="win-message" class="win-overlay">
      🎉 Puzzle Solved! Great job.
    </div>

  </div>
</div>

<script>
  // Game State
  const state = {
    puzzle: [],
    solution: [],
    userGrid: [],
    selectedCell: null // {r, c}
  };

  const els = {
    board: document.getElementById('board'),
    diffBtns: document.querySelectorAll('.diff-btn'),
    numBtns: document.querySelectorAll('.num-btn'),
    winMsg: document.getElementById('win-message')
  };

  // --- 1. AUTO-SAVE LOGIC ---
  function saveGame() {
    localStorage.setItem('gyanAmalaSudoku', JSON.stringify({
      puzzle: state.puzzle,
      solution: state.solution,
      userGrid: state.userGrid
    }));
  }

  function loadGame() {
    const saved = localStorage.getItem('gyanAmalaSudoku');
    if (saved) {
      const parsed = JSON.parse(saved);
      state.puzzle = parsed.puzzle;
      state.solution = parsed.solution;
      state.userGrid = parsed.userGrid;
      return true; // Successfully loaded saved game
    }
    return false; // No saved game found
  }

  function clearSavedGame() {
    localStorage.removeItem('gyanAmalaSudoku');
  }

  // --- 2. SUDOKU GENERATOR ---
  function generateBoard(difficulty) {
    // Base valid board
    let b = [
      [1,2,3,4,5,6,7,8,9], [4,5,6,7,8,9,1,2,3], [7,8,9,1,2,3,4,5,6],
      [2,3,4,5,6,7,8,9,1], [5,6,7,8,9,1,2,3,4], [8,9,1,2,3,4,5,6,7],
      [3,4,5,6,7,8,9,1,2], [6,7,8,9,1,2,3,4,5], [9,1,2,3,4,5,6,7,8]
    ];

    // Shuffle rows within 3x3 bands to randomize
    const swap = (r1, r2) => { let t = b[r1]; b[r1] = b[r2]; b[r2] = t; };
    for(let i=0; i<3; i++) {
      let band = i*3;
      if(Math.random() > 0.5) swap(band, band+1);
      if(Math.random() > 0.5) swap(band+1, band+2);
      if(Math.random() > 0.5) swap(band, band+2);
    }

    state.solution = b.map(row => [...row]);
    state.puzzle = b.map(row => [...row]);

    // Punch holes based on difficulty
    let blanks = difficulty === 'easy' ? 30 : difficulty === 'medium' ? 45 : 55;
    while(blanks > 0) {
      let r = Math.floor(Math.random() * 9), c = Math.floor(Math.random() * 9);
      if(state.puzzle[r][c] !== 0) {
        state.puzzle[r][c] = 0;
        blanks--;
      }
    }
    
    state.userGrid = state.puzzle.map(row => [...row]);
    saveGame(); // Save immediately when a new game starts
  }

  // --- 3. UI RENDERING ---
  function renderBoard() {
    els.board.innerHTML = '';
    els.winMsg.style.display = 'none';

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        let cell = document.createElement('div');
        cell.classList.add('cell');
        cell.dataset.r = r;
        cell.dataset.c = c;

        let val = state.userGrid[r][c];
        if (val !== 0) cell.textContent = val;

        if (state.puzzle[r][c] !== 0) {
          cell.classList.add('fixed');
        } else if (val !== 0) {
          cell.classList.add('user-input');
        }

        cell.addEventListener('click', () => selectCell(r, c));
        els.board.appendChild(cell);
      }
    }
    checkErrors();
  }

  function selectCell(r, c) {
    if(state.puzzle[r][c] !== 0) return; // Can't select fixed cells
    
    document.querySelectorAll('.cell').forEach(el => el.classList.remove('selected'));
    state.selectedCell = { r, c };
    
    let target = document.querySelector(`.cell[data-r="${r}"][data-c="${c}"]`);
    if(target) target.classList.add('selected');
  }

  // --- 4. INPUT HANDLING & VALIDATION ---
  function inputNumber(num) {
    if(!state.selectedCell) return;
    let {r, c} = state.selectedCell;
    
    state.userGrid[r][c] = num;
    saveGame(); // Save every time the user makes a move
    renderBoard();
    
    // Reselect the cell since renderBoard rebuilds the DOM
    selectCell(r, c);
    checkWin();
  }

  function checkErrors() {
    let cells = document.querySelectorAll('.cell');
    cells.forEach(c => c.classList.remove('error'));

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        let val = state.userGrid[r][c];
        if(val === 0 || state.puzzle[r][c] !== 0) continue; 

        // Check if user input matches the solution
        if(val !== state.solution[r][c]) {
           let el = document.querySelector(`.cell[data-r="${r}"][data-c="${c}"]`);
           if(el) el.classList.add('error');
        }
      }
    }
  }

  function checkWin() {
    let isFull = true;
    let isCorrect = true;

    for(let r = 0; r < 9; r++) {
      for(let c = 0; c < 9; c++) {
        if(state.userGrid[r][c] === 0) isFull = false;
        if(state.userGrid[r][c] !== state.solution[r][c]) isCorrect = false;
      }
    }

    if(isFull && isCorrect) {
      els.winMsg.style.display = 'block';
      state.selectedCell = null;
      document.querySelectorAll('.cell').forEach(el => el.classList.remove('selected'));
      clearSavedGame(); // Wipe the save so the next visit starts fresh
    }
  }

  // --- 5. EVENT LISTENERS ---
  
  // Difficulty Buttons
  els.diffBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      els.diffBtns.forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      generateBoard(e.target.dataset.diff);
      state.selectedCell = null;
      renderBoard();
    });
  });

  // On-Screen Numpad
  els.numBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      inputNumber(parseInt(e.target.dataset.val));
    });
  });

  // Physical Keyboard Support
  document.addEventListener('keydown', (e) => {
    if(e.key >= '1' && e.key <= '9') {
      inputNumber(parseInt(e.key));
    } else if (e.key === 'Backspace' || e.key === 'Delete') {
      inputNumber(0);
    }
  });

  // --- 6. INITIALIZATION ---
  // Try to load a saved game first. If it doesn't exist, start a new easy game.
  if (!loadGame()) {
    generateBoard('easy');
  }
  renderBoard();
</script>

